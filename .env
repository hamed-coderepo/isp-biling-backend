# ISP Report Generator environment variables (local/dev only)
# Replace placeholder values with real secrets on your server. Do NOT commit this file.

# Django
DJANGO_SECRET_KEY=dev-secret-for-local-testing
DJANGO_DEBUG=1
# Optional: comma-separated hostnames
ALLOWED_HOSTS=127.0.0.1,localhost,192.168.109.25

# CSRF trusted origins (must include scheme)
CSRF_TRUSTED_ORIGINS=http://127.0.0.1:8000,http://localhost:8000,http://192.168.109.25:8000

# Optional: multiple MariaDB sources (overrides single MARIA_* if set)
# Format: name,host,port,db,user,password;name2,host,port,db,user,password
# Example:
# MARIA_SOURCES=core,10.0.0.10,3306,deltasib,report_user,secret;branch2,10.0.0.11,3306,deltasib,report_user,secret
# NOTE: `name` is used as rs_name (db label), e.g. sib_ghor
MARIA_SOURCES=sib_ghor,203.171.110.195,3306,deltasib,report_user,Hamed*7bsli8y2nl!;hotspot2,103.161.237.138,3306,deltasib,report_user,Hamed*7bsli8y2nl!;hotspot3,103.161.237.218,3306,deltasib,report_user,Hamed*7bsli8y2nl!;
# Comma-separated table names to try when querying (order is priority)
BQ_TABLE_PRIORITY=Huser_servicebase,huser_servicebase_backup

# BigQuery settings
# REPORT_SOURCE can be: mariadb | bigquery
REPORT_SOURCE=bigquery
BQ_PROJECT=frsphotspots
BQ_DATASET=HSP
BQ_TABLE=report_user_service
BQ_LOCATION=US

# Automatic sync
AUTO_SYNC_ENABLED=0
AUTO_SYNC_INTERVAL_MINUTES=30

# If you use Google BigQuery as an alternative data source
GOOGLE_APPLICATION_CREDENTIALS=C:\Users\Laptop City\Desktop\Projects\Hotspot-Report\keys.json

# Service account JSON fields (optional reference for secrets/Cloud Run)
GCP_SA_TYPE=
GCP_SA_PROJECT_ID=
GCP_SA_PRIVATE_KEY_ID=
GCP_SA_PRIVATE_KEY=
GCP_SA_CLIENT_EMAIL=
GCP_SA_CLIENT_ID=
GCP_SA_AUTH_URI=https://accounts.google.com/o/oauth2/auth
GCP_SA_TOKEN_URI=https://oauth2.googleapis.com/token
GCP_SA_AUTH_PROVIDER_X509_CERT_URL=https://www.googleapis.com/oauth2/v1/certs
GCP_SA_CLIENT_X509_CERT_URL=https://www.googleapis.com/robot/v1/metadata/x509/frsphotspots%40appspot.gserviceaccount.com
GCP_SA_UNIVERSE_DOMAIN=googleapis.com
